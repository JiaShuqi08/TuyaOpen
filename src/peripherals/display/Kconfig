config ENABLE_DISPLAY
    bool "enable display"
    default n

if (ENABLE_DISPLAY)
    config DISPLAY_NAME
        string "the name of display 1"
        default "display"

    config ENABLE_DISPLAY_2
        bool "enable second display device"
        default n

    config DISPLAY_NAME_2
        string "the name of display 2"
        default "display2"
        depends on ENABLE_DISPLAY_2

    config DISPLAY_DEFAULT_BRIGHTNESS
        int "Default backlight brightness when opening display (0-100)"
        range 0 100
        default 100
        help
            Applied by tdl_disp_dev_open() after backlight hardware is initialized.
            0 turns backlight off where supported; 100 is maximum. For GPIO on/off
            backlight, any non-zero value turns the backlight on.
endif