config CHIP_CHOICE
    string
    default "esp32c3"

config BOARD_CHOICE
    string
    default "XTEINK_X4"

config BOARD_CONFIG
    bool
    default y
    select PLATFORM_FLASHSIZE_16M

config UART_NUM0_TX_PIN
    int "UART_NUM0_TX_PIN"
    range 0 21
    default 18
    ---help---
        Xteink X4 uses GPIO20 for USB charge sense; avoid UART on GPIO20/21 if possible.
        Default 18 may be used for console when USB-CDC is not the log output.

config UART_NUM0_RX_PIN
    int "UART_NUM0_RX_PIN"
    range 0 21
    default 19
    ---help---
        Paired with UART_NUM0_TX_PIN for UART0.
